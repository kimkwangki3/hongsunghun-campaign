# backend/.env.example (프로덕션 Render 배포용)
DATABASE_URL=postgresql://campaign:password@hostname:5432/campaign
NODE_ENV=production
PORT=10000
JWT_SECRET=캠프전용시크릿키_최소32자_여기에입력
INVITE_CODE=camp2026
ALLOWED_ORIGINS=https://your-render-app.onrender.com

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
